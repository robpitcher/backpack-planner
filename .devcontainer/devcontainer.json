{
  "name": "TrailForge Dev",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "forwardPorts": [5173, 54321, 54322, 54323],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server", "onAutoForward": "notify" },
    "54321": { "label": "Supabase API", "onAutoForward": "notify" },
    "54322": { "label": "Supabase DB", "onAutoForward": "silent" },
    "54323": { "label": "Supabase Studio", "onAutoForward": "notify" }
  },
  "postCreateCommand": "npm install && npm install -g supabase",
  "postStartCommand": "cp -n .env.local.example .env.local 2>/dev/null; echo 'Ready — run: supabase start && npm run dev'",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "supabase.supabase-js-vscode"
      ],
      "settings": {}
    }
  }
}
